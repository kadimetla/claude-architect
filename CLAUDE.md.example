"""Basic agentic loop pattern for the CCA-F exam.

Demonstrates the core loop: send request, check stop_reason,
execute tools if needed, continue until end_turn.

CCA-F Domain 1, Task Statement 1.1
"""

import anthropic
import json

client = anthropic.Anthropic()
MODEL = "claude-sonnet-4-20250514"

tools = [
    {
        "name": "get_weather",
        "description": (
            "Get current weather for a city. "
            "Input: city name string. Returns: temperature, conditions, humidity. "
            "Use for current conditions only. NOT for forecasts."
        ),
        "input_schema": {
            "type": "object",
            "properties": {
                "city": {"type": "string", "description": "City name, e.g. 'Nashville'"}
            },
            "required": ["city"]
        }
    }
]


def execute_tool(tool_name: str, tool_input: dict) -> str:
    """Execute a tool call. In production, dispatches to real backends."""
    if tool_name == "get_weather":
        return json.dumps({"city": tool_input["city"], "temp": 72, "conditions": "partly cloudy"})
    return json.dumps({"error": f"Unknown tool: {tool_name}"})


def run_agent(user_message: str) -> str:
    """Run the agentic loop until end_turn.

    Key: loop continues on stop_reason='tool_use',
    terminates on stop_reason='end_turn'.
    Do NOT parse NL signals or set arbitrary caps.
    """
    messages = [{"role": "user", "content": user_message}]

    while True:
        response = client.messages.create(
            model=MODEL, max_tokens=1024, tools=tools, messages=messages
        )

        if response.stop_reason == "end_turn":
            return "".join(b.text for b in response.content if b.type == "text")

        elif response.stop_reason == "tool_use":
            messages.append({"role": "assistant", "content": response.content})
            tool_results = []
            for block in response.content:
                if block.type == "tool_use":
                    result = execute_tool(block.name, block.input)
                    tool_results.append({
                        "type": "tool_result",
                        "tool_use_id": block.id,
                        "content": result
                    })
            messages.append({"role": "user", "content": tool_results})

        else:
            return f"Unexpected stop_reason: {response.stop_reason}"


if __name__ == "__main__":
    print(run_agent("What is the weather like in Nashville right now?"))
