{
  "name": "cca-cert-buddy",
  "version": "1.0.0",
  "description": "Self-contained CCA-F exam study aid whose own architecture demonstrates every CCA-F domain: MCP client + server, subagents, the agentic loop, structured output.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "seed": "tsx scripts/seed-bank.ts",
    "generate": "tsx scripts/generate-questions.ts",
    "validate:bank": "tsx scripts/validate-bank.ts",
    "mcp": "tsx mcp-server/index.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "dev": "npm-run-all --parallel dev:server dev:client",
    "build": "npm-run-all build:client build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.json",
    "start": "node dist/server/index.js",
    "test": "node --test --import tsx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.98.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/supertest": "^6.0.2",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.2.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
