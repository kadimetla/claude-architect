# CCA Cert Buddy - environment configuration
#
# The app runs fully on the pre-generated question bank with NO key.
# A key is only needed for two optional features:
#   1. Live single-question generation (the /generate page)
#   2. The build-time question generator (npm run generate)
#
# Get a key at https://console.anthropic.com/

ANTHROPIC_API_KEY=

# Port the Express backend listens on. The Vite dev server proxies /api here.
PORT=3000
